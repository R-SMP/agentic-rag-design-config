# --- Secrets (NEVER commit these) ---
.env
*.env
!.env.example
!*.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environment ---
.venv/
venv/
env/

# --- Runtime artefacts (generated by the system) ---
logs/
attempts/
database/
previous_sessions/
inputs/input_images/*
!inputs/input_images/.gitkeep
inputs/user_query.txt
inputs/extracted_inputs.txt

# --- Prompt-fragment snapshot backups ---
prompts_backup_*/

# --- Claude Code (per-user) ---
.claude/settings.local.json

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
