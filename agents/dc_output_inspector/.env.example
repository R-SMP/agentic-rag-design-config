# Per-agent LLM override for the Dc Output Inspector.
#
# Copy this file to ".env" in the same folder and uncomment the
# variables to override the shared agent defaults from agents/.env.
# Leave this file uncopied (or empty / partially filled) to use the
# shared default.  An agent override is honoured ONLY when both a
# valid LLM_PROVIDER and the matching API key are set here.
#
# Supported providers: openai | google | anthropic
# LLM_PROVIDER=openai
# MODEL_NAME=gpt-5-mini
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...
