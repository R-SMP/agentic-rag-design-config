# v3 environment-variable inventory.  Copy this file to .env (NOT
# committed — see .gitignore) and fill in real values; never put
# real values in this file.
#
# Some keys are required for v4 REPL too (LLM keys, Rhino Compute);
# others are only consumed by v3-specific code that lands in later
# Phase 2+ commits.

# ----------------------------------------------------------------------
# LLM providers (used by v4 REPL and v3 Streamlit alike)
# ----------------------------------------------------------------------
# These can also be placed inside agents/.env (per-agent override
# also possible via agents/<agent>/.env).  Set whichever you prefer
# — root .env is read by config.py, agents/.env is read by
# agents/shared/llm_provider.py.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ----------------------------------------------------------------------
# Rhino Compute (existing Azure VM or local rhinocompute server)
# ----------------------------------------------------------------------
# Local rhinocompute defaults to http://localhost:6500/.  Production
# v3 will point this at the Azure VM — see TODO_known_issues.md and
# the supplement (region confirmation pending).
RHINO_COMPUTE_URL=http://localhost:6500/
RHINO_COMPUTE_API_KEY=

# ----------------------------------------------------------------------
# Postgres (Phase 2 onwards)
# ----------------------------------------------------------------------
# Local docker-compose default:
#   postgresql://postgres:postgres@localhost:5432/propeller_dev
# Railway production: copy DATABASE_URL from the Railway Postgres
# service Variables tab (auto-injected when running on Railway).
DATABASE_URL=

# ----------------------------------------------------------------------
# Cloudflare R2 (Phase 5 onwards — binary artefact storage)
# ----------------------------------------------------------------------
# All four are required when STORAGE_BACKEND=postgres and binaries
# need to be uploaded.  Get them from the Cloudflare dashboard for
# the R2 bucket created during Stage B setup (the old
# mt-propeller-v11-artefacts bucket is dead — see the deploy
# runbook intro).  Keys live in NordPass — never paste them in chat.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ----------------------------------------------------------------------
# Auth (Phase 4)
# ----------------------------------------------------------------------
# Single shared invite code.  Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# Rotate by changing this and restarting the Streamlit service.
INVITE_CODE=

# ----------------------------------------------------------------------
# Storage backend selector
# ----------------------------------------------------------------------
# Selects which save path the Database Handler runs at session end:
#   files     v4 REPL — writes per-field .txt files under
#             database/<session>/<agent>/<field>.txt (no Postgres
#             dependency; useful for fast prompt-iteration work)
#   postgres  v3 cloud — builds a SaveBatch and writes to Postgres
#             in one transaction, plus uploads binaries to R2
# Default is ``files`` so v4 REPL works without any v3 envvars set.
STORAGE_BACKEND=files
